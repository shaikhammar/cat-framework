{
    "name": "catframework/filter-pptx",
    "description": "PowerPoint (.pptx) file filter for the CAT Framework",
    "type": "library",
    "license": "MIT",
    "version": "0.1.0",
    "require": {
        "php": "^8.2",
        "catframework/core": "^0.1",
        "ext-zip": "*",
        "ext-dom": "*",
        "ext-libxml": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "CatFramework\\FilterPptx\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CatFramework\\FilterPptx\\Tests\\": "tests/"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../core"
        }
    ],
    "config": {
        "sort-packages": true
    }
}
