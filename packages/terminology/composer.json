{
    "name": "catframework/terminology",
    "description": "Term recognition and TBX import for the CAT Framework",
    "type": "library",
    "license": "MIT",
    "version": "0.1.0",
    "require": {
        "php": "^8.2",
        "ext-dom": "*",
        "ext-intl": "*",
        "ext-mbstring": "*",
        "ext-pdo": "*",
        "ext-pdo_sqlite": "*",
        "catframework/core": "^0.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "CatFramework\\Terminology\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CatFramework\\Terminology\\Tests\\": "tests/"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../core"
        }
    ],
    "config": {
        "sort-packages": true
    }
}
