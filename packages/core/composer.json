{
    "name": "catframework/core",
    "description": "Shared data models and contract interfaces for the CAT Framework",
    "type": "library",
    "license": "MIT",
    "version": "0.1.0",
    "require": {
        "php": "^8.2",
        "ext-intl": "*",
        "ext-mbstring": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "CatFramework\\Core\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CatFramework\\Core\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    }
}
