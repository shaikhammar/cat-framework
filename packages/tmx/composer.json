{
    "name": "catframework/tmx",
    "description": "TMX 1.4b parser and writer for the CAT Framework",
    "type": "library",
    "version": "0.1.0",
    "require": {
        "php": "^8.2",
        "ext-dom": "*",
        "ext-libxml": "*",
        "ext-xmlreader": "*",
        "catframework/core": "^0.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "CatFramework\\Tmx\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CatFramework\\Tmx\\Tests\\": "tests/"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../core"
        }
    ]
}
