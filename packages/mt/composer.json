{
    "name": "catframework/mt",
    "description": "Machine translation adapter framework for the CAT Framework",
    "type": "library",
    "license": "MIT",
    "version": "0.1.0",
    "require": {
        "php": "^8.2",
        "catframework/core": "^0.1",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/http-message": "^1.1 || ^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "CatFramework\\Mt\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CatFramework\\Mt\\Tests\\": "tests/"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../core"
        }
    ],
    "config": {
        "sort-packages": true
    }
}
