{
    "name": "catframework/xliff",
    "description": "XLIFF 1.2 writer and reader for the CAT Framework",
    "type": "library",
    "version": "0.1.0",
    "require": {
        "php": "^8.2",
        "ext-dom": "*",
        "ext-libxml": "*",
        "catframework/core": "^0.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "CatFramework\\Xliff\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CatFramework\\Xliff\\Tests\\": "tests/"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../core"
        }
    ]
}
